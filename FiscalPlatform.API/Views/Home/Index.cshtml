@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>FiscalPRO — Plateforme Fiscale Tunisienne</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<style>
/* ═══════════════════════════════════════════════
   DESIGN TOKENS
═══════════════════════════════════════════════ */
:root{
  --black:   #000;  --gold:   #FFD000;  --white: #fff;
  --off:     #F5F5F5; --border:#DDD;   --muted: #666;
  --text:    #111;  --red:    #C62828; --green: #1B5E20;
  --purple:  #4527A0; --teal:  #00695C;
  --shadow:  0 2px 12px rgba(0,0,0,.13);
  --r:       6px;   --nav-h: 64px; --sidebar-w: 250px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:14px;scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--off);color:var(--text);min-height:100vh}
button{cursor:pointer;border:none;outline:none;font-family:inherit}
input,textarea,select{font-family:inherit;outline:none}
a{text-decoration:none;color:inherit}

/* ── Navbar ── */
.navbar{
  position:fixed;top:0;left:0;right:0;z-index:1000;
  height:var(--nav-h);background:var(--black);
  border-bottom:4px solid var(--gold);
  display:flex;align-items:center;padding:0 20px;gap:0;
  box-shadow:0 4px 12px rgba(0,0,0,.3);
}
.nav-brand{
  font-family:'Playfair Display',serif;font-size:16px;font-weight:700;
  color:var(--white);letter-spacing:2px;white-space:nowrap;
  padding-right:20px;border-right:2px solid var(--gold);
  text-transform:uppercase;display:flex;align-items:center;gap:10px;
}
.nav-brand img{height:44px;width:auto;object-fit:contain}
.nav-links{display:flex;align-items:center;gap:2px;padding-left:16px;flex:1}
.nav-link{
  color:rgba(255,255,255,.75);font-size:12.5px;font-weight:600;
  padding:6px 14px;border-radius:4px;transition:.15s;white-space:nowrap;
  text-transform:uppercase;letter-spacing:.5px;
}
.nav-link:hover,.nav-link.active{background:var(--gold);color:var(--black)}
.nav-right{display:flex;align-items:center;gap:10px;margin-left:auto}
.nav-badge{
  font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;
  background:var(--gold);color:var(--black);letter-spacing:.5px;text-transform:uppercase;
}
.status-dot{width:8px;height:8px;border-radius:50%;background:#4CAF50;
  border:2px solid rgba(255,255,255,.4);display:inline-block}
.status-dot.red{background:#ef5350}

/* ── Layout ── */
.shell{display:flex;padding-top:var(--nav-h);min-height:100vh}
.sidebar{
  width:var(--sidebar-w);flex-shrink:0;background:var(--white);
  border-right:1px solid var(--border);position:fixed;
  top:var(--nav-h);bottom:0;left:0;overflow-y:auto;padding:0;
}
.sidebar::-webkit-scrollbar{width:4px}
.sidebar::-webkit-scrollbar-thumb{background:#ddd;border-radius:4px}
.sb-section{padding:14px 14px 8px}
.sb-title{
  font-size:10px;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;
  color:var(--muted);margin-bottom:10px;padding-bottom:6px;
  border-bottom:1px solid var(--border);
}
.stat-card{
  background:var(--off);border:1px solid var(--border);
  border-radius:var(--r);padding:10px 12px;margin-bottom:8px;
}
.stat-card-label{font-size:11px;color:var(--muted);margin-bottom:2px}
.stat-card-val{font-family:'JetBrains Mono',monospace;font-size:18px;font-weight:500;color:var(--black)}
.doc-type-bar{display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:var(--r);margin-bottom:3px}
.doc-type-bar:hover{background:var(--off)}
.doc-type-icon{font-size:14px;width:22px;text-align:center}
.doc-type-label{font-size:12px;flex:1;font-weight:500}
.doc-type-count{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--muted)}
.sb-chip-list{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:10px}
.sb-chip{
  font-size:11px;padding:3px 9px;border-radius:20px;
  background:var(--off);border:1px solid var(--border);
  color:var(--text);cursor:pointer;transition:.12s;font-weight:500;
}
.sb-chip:hover{background:var(--gold);color:var(--black);border-color:var(--gold);font-weight:700}
.sb-select{
  width:100%;padding:7px 10px;border:1px solid var(--border);border-radius:var(--r);
  font-size:12px;color:var(--text);background:var(--off);
  appearance:none;cursor:pointer;margin-bottom:10px;
}
.sb-filter-label{font-size:12px;font-weight:600;color:var(--text);margin-bottom:4px;display:block}

.main-content{margin-left:var(--sidebar-w);flex:1;padding:24px 28px;min-height:calc(100vh - var(--nav-h))}

/* ── Tab bar ── */
.tab-bar{
  display:flex;gap:0;margin-bottom:22px;
  border:1px solid var(--border);border-radius:8px;
  background:var(--white);padding:4px;width:fit-content;
  box-shadow:var(--shadow);
}
.tab-btn{
  padding:8px 22px;border-radius:5px;font-size:13px;font-weight:700;
  color:var(--muted);background:transparent;transition:.15s;letter-spacing:.3px;
  display:flex;align-items:center;gap:7px;text-transform:uppercase;
}
.tab-btn.active{background:var(--black);color:var(--gold);box-shadow:0 3px 10px rgba(0,0,0,.3)}
.tab-btn:hover:not(.active){background:var(--off);color:var(--text)}

/* ═══════════════════════════════════════════════
   SEARCH PANEL
═══════════════════════════════════════════════ */
.search-box{
  background:var(--white);border:1px solid var(--border);border-radius:8px;
  padding:20px;margin-bottom:18px;box-shadow:var(--shadow);
}
.search-row{display:flex;gap:10px;align-items:center}
.search-input{
  flex:1;padding:11px 16px;border:2px solid var(--border);border-radius:var(--r);
  font-size:14px;color:var(--text);background:var(--off);transition:.15s;
}
.search-input:focus{border-color:var(--gold);background:var(--white);box-shadow:0 0 0 3px rgba(255,208,0,.15)}
.search-input::placeholder{color:var(--muted)}
.btn-primary{
  padding:10px 22px;background:var(--gold);color:var(--black);
  font-size:13px;font-weight:700;border-radius:var(--r);
  letter-spacing:.5px;transition:.15s;white-space:nowrap;
  box-shadow:0 3px 12px rgba(255,208,0,.4);text-transform:uppercase;
}
.btn-primary:hover{box-shadow:0 5px 18px rgba(255,208,0,.5);transform:translateY(-2px)}
.btn-primary:disabled{opacity:.5;cursor:not-allowed;transform:none}
.search-hint{font-size:11px;color:var(--muted);margin-top:7px}
.year-row{display:flex;align-items:center;gap:10px;margin-top:10px}
.year-label{font-size:12px;color:var(--muted);white-space:nowrap}
.year-input{width:75px;padding:6px 8px;border:1px solid var(--border);border-radius:4px;font-size:12px;background:var(--off)}
.metrics-row{display:flex;gap:10px;margin-bottom:14px;flex-wrap:wrap}
.metric-pill{background:var(--white);border:1px solid var(--border);border-radius:20px;padding:5px 14px;font-size:12px}
.metric-pill b{color:var(--black)}
.result-card{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:15px 18px;margin-bottom:10px;transition:.15s;border-left:4px solid transparent}
.result-card.top{border-left-color:var(--gold);border-left-width:6px;background:rgba(255,208,0,.04)}
.result-card:hover{box-shadow:0 4px 16px rgba(0,0,0,.1)}
.card-row{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:7px}
.card-rank{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--muted);margin-right:8px;flex-shrink:0}
.card-title{font-size:14px;font-weight:700;color:var(--black);flex:1;line-height:1.4}
.card-score-badge{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:700;background:var(--gold);color:var(--black);padding:4px 10px;border-radius:10px;white-space:nowrap;margin-left:12px}
.tags-row{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:8px}
.tag{font-size:10px;font-weight:700;padding:2px 8px;border-radius:2px;text-transform:uppercase;letter-spacing:.5px}
.tag-loi{background:#DBEAFE;color:#1E40AF}
.tag-note{background:#DCFCE7;color:#166534}
.tag-article{background:#FEF3C7;color:#92400E}
.tag-section{background:#F3E8FF;color:#6B21A8}
.tag-table{background:#F0FDF4;color:#15803D}
.tag-other{background:#F1F5F9;color:#475569}
.snippet{font-size:13px;color:#374151;line-height:1.75;border-top:1px solid #F0F4F8;padding-top:8px}
.snippet em{background:#FEF08A;color:var(--black);font-style:normal;padding:1px 2px;border-radius:2px}
.score-track{background:#E5E7EB;border-radius:3px;height:3px;margin-top:8px}
.score-fill{background:linear-gradient(90deg,var(--gold),#FFC700);border-radius:3px;height:3px}
.card-meta{font-size:11px;color:var(--muted);margin-top:7px}
/* ── Consultation history cards ──────────────────── */
.consult-card{
  background:var(--white);border:1px solid var(--gold);
  border-radius:var(--r);padding:16px 18px;margin-bottom:12px;
  border-left:5px solid var(--gold);
  box-shadow:0 2px 8px rgba(255,208,0,.15);
}
.consult-client{
  font-family:'Playfair Display',serif;font-size:16px;
  font-weight:700;color:var(--black);margin-bottom:4px;
}
.consult-meta{
  font-size:11px;color:var(--muted);margin-bottom:10px;
  display:flex;gap:12px;flex-wrap:wrap;
}
.consult-sommaire{
  font-size:13px;color:var(--text);line-height:1.6;
  border-left:3px solid var(--gold);padding-left:10px;
  margin-bottom:8px;white-space:pre-wrap;
}
.consult-expand-btn{
  font-size:11px;color:var(--muted);background:none;
  border:1px solid var(--border);border-radius:4px;
  padding:3px 10px;cursor:pointer;margin-top:4px;
}
.consult-analyses{
  display:none;font-size:12px;color:var(--text);margin-top:10px;
  max-height:500px;overflow-y:auto;white-space:pre-wrap;
  background:var(--off);border-radius:4px;padding:12px;line-height:1.7;
}
.section-divider{text-align:center;padding:14px 0 10px;color:var(--muted);font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;border-top:1px dashed var(--border);margin:4px 0}
.show-more-btn{width:100%;padding:10px;background:var(--off);border:1px solid var(--border);border-radius:var(--r);font-size:12px;font-weight:600;color:var(--muted);cursor:pointer;transition:.15s;margin-bottom:12px}
.show-more-btn:hover{background:var(--border);color:var(--text)}

/* ═══════════════════════════════════════════════
   CONSULTATION PANEL
═══════════════════════════════════════════════ */
.cons-layout{display:grid;grid-template-columns:1fr 340px;gap:20px;align-items:start}

.cons-form-card{
  background:var(--white);border:1px solid var(--border);border-radius:8px;
  box-shadow:var(--shadow);overflow:hidden;
}
.cons-form-header{
  background:var(--black);padding:16px 22px;display:flex;align-items:center;gap:12px;
  border-bottom:4px solid var(--gold);
}
.cons-form-title{font-family:'Playfair Display',serif;font-size:15px;font-weight:700;color:var(--gold);text-transform:uppercase;letter-spacing:.5px}
.cons-form-sub{font-size:11px;color:rgba(255,255,255,.65);margin-top:2px}
.cons-form-body{padding:22px}

.form-group{margin-bottom:18px}
.form-label{font-size:12px;font-weight:700;color:var(--text);margin-bottom:6px;display:block;text-transform:uppercase;letter-spacing:.5px}
.form-label span{font-weight:400;color:var(--muted);text-transform:none;letter-spacing:0}
.form-input{
  width:100%;padding:10px 13px;border:1.5px solid var(--border);border-radius:var(--r);
  font-size:13px;color:var(--text);background:var(--off);transition:.15s;
}
.form-input:focus{border-color:var(--gold);background:var(--white);box-shadow:0 0 0 3px rgba(255,208,0,.12)}
.form-textarea{
  width:100%;padding:11px 13px;border:1.5px solid var(--border);border-radius:var(--r);
  font-size:13px;color:var(--text);background:var(--off);resize:vertical;
  transition:.15s;line-height:1.6;
}
.form-textarea:focus{border-color:var(--gold);background:var(--white);box-shadow:0 0 0 3px rgba(255,208,0,.12)}
.form-textarea::placeholder,.form-input::placeholder{color:var(--muted)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px}

/* Document chips */
.doc-chips{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px}
.doc-chip{
  display:flex;align-items:center;gap:6px;
  background:var(--off);border:1px solid var(--border);border-radius:20px;
  padding:4px 10px 4px 12px;font-size:12px;font-weight:500;
}
.doc-chip-remove{
  background:none;border:none;color:var(--muted);font-size:14px;
  cursor:pointer;padding:0;line-height:1;
}
.doc-chip-remove:hover{color:var(--red)}
.doc-add-row{display:flex;gap:8px}
.doc-add-input{
  flex:1;padding:8px 12px;border:1.5px solid var(--border);border-radius:var(--r);
  font-size:13px;background:var(--off);
}
.doc-add-input:focus{border-color:var(--gold);background:var(--white)}
.btn-ghost{
  padding:8px 14px;background:var(--off);border:1px solid var(--border);
  border-radius:var(--r);font-size:12px;font-weight:600;color:var(--text);
  cursor:pointer;transition:.12s;
}
.btn-ghost:hover{background:var(--gold);color:var(--black);border-color:var(--gold)}

.btn-generate{
  width:100%;padding:14px;background:var(--gold);color:var(--black);
  font-size:14px;font-weight:800;border-radius:var(--r);
  letter-spacing:.5px;transition:.15s;text-transform:uppercase;
  box-shadow:0 4px 14px rgba(255,208,0,.45);margin-top:6px;
}
.btn-generate:hover:not(:disabled){box-shadow:0 6px 20px rgba(255,208,0,.6);transform:translateY(-2px)}
.btn-generate:disabled{opacity:.55;cursor:not-allowed;transform:none}

/* ── Progress panel ── */
.progress-card{
  background:var(--white);border:1px solid var(--border);border-radius:8px;
  box-shadow:var(--shadow);overflow:hidden;
}
.progress-header{
  background:var(--off);border-bottom:1px solid var(--border);
  padding:12px 16px;font-size:12px;font-weight:700;color:var(--text);letter-spacing:.3px;
}
.progress-body{padding:16px}
.progress-step{
  display:flex;align-items:center;gap:10px;padding:9px 0;
  border-bottom:1px solid var(--off);font-size:13px;color:var(--muted);
}
.progress-step:last-child{border-bottom:none}
.progress-step.done{color:var(--green);font-weight:600}
.progress-step.active{color:var(--black);font-weight:700}
.step-icon{font-size:16px;width:22px;text-align:center;flex-shrink:0}
.step-spinner{
  display:inline-block;width:16px;height:16px;border-radius:50%;
  border:2px solid var(--gold);border-top-color:transparent;
  animation:spin .8s linear infinite;flex-shrink:0;
}
@@keyframes spin{to{transform:rotate(360deg)}}

/* Download button */
.btn-download{
  width:100%;margin-top:14px;padding:12px;
  background:var(--green);color:var(--white);font-size:13px;font-weight:700;
  border-radius:var(--r);display:flex;align-items:center;justify-content:center;gap:8px;
  box-shadow:0 3px 12px rgba(27,94,32,.35);transition:.15s;text-transform:uppercase;
  letter-spacing:.5px;
}
.btn-download:hover{box-shadow:0 5px 18px rgba(27,94,32,.5);transform:translateY(-1px)}

/* Sidebar guide for consultation */
.guide-card{background:var(--white);border:1px solid var(--border);border-radius:8px;box-shadow:var(--shadow);overflow:hidden}
.guide-header{background:var(--black);padding:12px 16px;font-size:12px;font-weight:700;color:var(--gold);letter-spacing:.3px}
.guide-body{padding:14px}
.guide-section{margin-bottom:14px}
.guide-section-title{font-size:11px;font-weight:700;color:var(--text);text-transform:uppercase;letter-spacing:.5px;margin-bottom:6px;display:flex;align-items:center;gap:6px}
.guide-item{font-size:12px;color:var(--muted);padding:4px 0;border-bottom:1px solid var(--off);line-height:1.4}
.guide-item:last-child{border-bottom:none}

/* ═══════════════════════════════════════════════
   STATS PANEL
═══════════════════════════════════════════════ */
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:22px}
.stats-conn{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:14px 18px;margin-top:4px}

/* ═══════════════════════════════════════════════
   SHARED
═══════════════════════════════════════════════ */
.empty-state{text-align:center;padding:60px 20px;color:var(--muted)}
.empty-icon{font-size:48px;margin-bottom:14px}
.empty-title{font-family:'Playfair Display',serif;font-size:20px;color:var(--black);margin-bottom:8px;font-weight:700}
.empty-sub{font-size:13px;line-height:1.6}
.skeleton{background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);background-size:200% 100%;animation:shimmer 1.4s infinite;border-radius:4px}
@@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
.toast-container{position:fixed;bottom:20px;right:20px;z-index:9999;display:flex;flex-direction:column;gap:8px}
.toast{padding:10px 16px;border-radius:6px;font-size:13px;font-weight:700;background:var(--black);color:var(--gold);box-shadow:0 4px 16px rgba(0,0,0,.4);animation:slideIn .25s ease;max-width:320px;text-transform:uppercase;letter-spacing:.3px}
.toast.error{background:var(--red);color:var(--white)}
.toast.success{background:#2E7D32;color:var(--white)}
.toast.info{background:#1565C0;color:var(--white)}
@@keyframes slideIn{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:none}}
.footer{text-align:center;color:var(--muted);font-size:11px;padding:20px;border-top:1px solid var(--border);margin-top:40px}
@@media(max-width:900px){
  .sidebar{display:none}
  .main-content{margin-left:0}
  .cons-layout{grid-template-columns:1fr}
  .form-row{grid-template-columns:1fr}
}
</style>
</head>
<body>

<!-- ══════════ NAVBAR ══════════ -->
<nav class="navbar">
  <div class="nav-brand">
    <img src="/ey-logo-black.jpg" alt="EY Logo"/>
    <span><span style="color:var(--gold)">Fiscal</span><span style="color:#fff">PRO</span></span>
  </div>
  <div class="nav-links">
    <a class="nav-link active" href="#" onclick="showTab('search');return false">Recherche</a>
    <a class="nav-link" href="#" onclick="showTab('consultation');return false">Consultation IA</a>
    <a class="nav-link" href="#" onclick="showTab('stats');return false">Statistiques</a>
  </div>
  <div class="nav-right">
    <span class="status-dot" id="esStatusDot" title="Elasticsearch"></span>
    <span class="status-dot" id="neo4jStatusDot" title="Neo4j"></span>
    <span class="nav-badge">🇹🇳 ProFiscal</span>
  </div>
</nav>

<!-- ══════════ LAYOUT ══════════ -->
<div class="shell">

  <!-- ── SIDEBAR ── -->
  <aside class="sidebar">

    <!-- Knowledge-base stats -->
    <div class="sb-section">
      <div class="sb-title">Base de Connaissances</div>
      <div class="stat-card"><div class="stat-card-label">Chunks ES</div><div class="stat-card-val" id="sbEsCount">—</div></div>
      <div class="stat-card"><div class="stat-card-label">Chunks Neo4j</div><div class="stat-card-val" id="sbNeoCount">—</div></div>
      <div class="stat-card"><div class="stat-card-label">Entités / Relations</div><div class="stat-card-val" id="sbEntRel">—</div></div>
    </div>

    <!-- Doc types -->
    <div class="sb-section">
      <div class="sb-title">Types de Documents</div>
      <div class="doc-type-bar"><span class="doc-type-icon">📋</span><span class="doc-type-label">Loi de Finances</span><span class="doc-type-count" id="sbLoi">—</span></div>
      <div class="doc-type-bar"><span class="doc-type-icon">📝</span><span class="doc-type-label">Notes Communes</span><span class="doc-type-count" id="sbNote">—</span></div>
      <div class="doc-type-bar"><span class="doc-type-icon">📖</span><span class="doc-type-label">Code Local</span><span class="doc-type-count" id="sbCode">—</span></div>
      <div class="doc-type-bar"><span class="doc-type-icon">🤝</span><span class="doc-type-label">Conventions</span><span class="doc-type-count" id="sbConv">—</span></div>
    </div>

    <!-- Quick searches (visible when Search tab is active) -->
    <div class="sb-section" id="sbQuickSearch">
      <div class="sb-title">Recherches Rapides</div>
      <div class="sb-chip-list">
        <span class="sb-chip" onclick="quickSearch('TVA')">TVA</span>
        <span class="sb-chip" onclick="quickSearch('retenue source')">Retenue source</span>
        <span class="sb-chip" onclick="quickSearch('article 52')">Art. 52</span>
        <span class="sb-chip" onclick="quickSearch('impot societes')">IS</span>
        <span class="sb-chip" onclick="quickSearch('penalite retard')">Pénalité</span>
        <span class="sb-chip" onclick="quickSearch('declaration')">Déclaration</span>
