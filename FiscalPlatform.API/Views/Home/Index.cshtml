<!-- ═══════════════ JAVASCRIPT ═══════════════ -->
<script>
// ── State ─────────────────────────────────────────────────────────────────────
let docs          = [];
let lastDocBlob   = null;
let lastDocName   = '';
let searchData    = null;
let showingAll    = false;

// ── Tag config ────────────────────────────────────────────────────────────────
const TAG_CSS = {
  loi:'tag-loi', note_commune:'tag-note', article:'tag-article',
  article_part:'tag-article', section:'tag-section', subsection:'tag-section',
  text_table:'tag-table', image_table:'tag-table', preamble:'tag-other',
  full_document:'tag-other', resume:'tag-other', text:'tag-other', table:'tag-table'
};
const TAG_LABELS = {
  loi:'Loi', note_commune:'Note Commune', article:'Article',
  article_part:'Article ↩', section:'Section', subsection:'Sous-section',
  text_table:'Tableau', image_table:'Tableau IMG', preamble:'Préambule',
  full_document:'Document', text:'Texte', table:'Tableau', resume:'Résumé'
};

// ── Tab switching ─────────────────────────────────────────────────────────────
function showTab(tab) {
  ['search','consultation','stats'].forEach(t => {
    const panel = document.getElementById(`panel${cap(t)}`);
    const btn   = document.getElementById(`tab${cap(t)}`);
    if (panel) panel.style.display = t === tab ? '' : 'none';
    if (btn)   btn.classList.toggle('active', t === tab);
  });
  document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
  const links = document.querySelectorAll('.nav-link');
  if (tab === 'search')       links[0]?.classList.add('active');
  if (tab === 'consultation') links[1]?.classList.add('active');
  if (tab === 'stats')        links[2]?.classList.add('active');

  // Show/hide sidebar sections depending on tab
  const showSearchSb = tab === 'search';
  document.getElementById('sbQuickSearch').style.display = showSearchSb ? '' : 'none';
  document.getElementById('sbFilters').style.display     = showSearchSb ? '' : 'none';

  if (tab === 'stats') populateStatPanel();
}
const cap = s => s.charAt(0).toUpperCase() + s.slice(1);

// ── Sidebar stats on load ─────────────────────────────────────────────────────
async function loadStats() {
  try {
    const [esH, neo4jH, statsR] = await Promise.allSettled([
      fetch('/api/search/health').then(r => r.json()),
      fetch('/api/consultation/health').then(r => r.json()),
      fetch('/api/stats').then(r => r.json())
    ]);
    const esOk    = esH.status === 'fulfilled'    && esH.value.alive;
    const neo4jOk = neo4jH.status === 'fulfilled' && neo4jH.value.alive;
    const setDot = (id, ok) => {
      document.getElementById(id).className = 'status-dot' + (ok ? '' : ' red');
      document.getElementById(id).title = ok ? '✅ Connecté' : '❌ Hors ligne';
    };
    setDot('esStatusDot',   esOk);
    setDot('neo4jStatusDot',neo4jOk);

    if (esH.status === 'fulfilled')
      document.getElementById('sbEsCount').textContent = (esH.value.count || 0).toLocaleString('fr');
    if (statsR.status === 'fulfilled') {
      const s = statsR.value;
      document.getElementById('sbNeoCount').textContent = (s.totalChunks  || 0).toLocaleString('fr');
      document.getElementById('sbEntRel').textContent   = `${(s.totalEntities||0).toLocaleString('fr')} / ${(s.totalRelations||0).toLocaleString('fr')}`;
      document.getElementById('sbLoi').textContent  = (s.loisCount        || 0).toLocaleString('fr');
      document.getElementById('sbNote').textContent  = (s.notesCount       || 0).toLocaleString('fr');
      document.getElementById('sbCode').textContent  = (s.codesCount       || 0).toLocaleString('fr');
      document.getElementById('sbConv').textContent  = (s.conventionsCount || 0).toLocaleString('fr');
      document.getElementById('footerGnn').textContent = `GNN: ${s.gnnActive ? 'Actif ✅' : 'Inactif'}`;
    }
  } catch(e) { console.warn('loadStats failed', e); }
}

// ── Stats panel (full page) ───────────────────────────────────────────────────
async function populateStatPanel() {
  try {
    const [esH, neo4jH, statsR] = await Promise.allSettled([
      fetch('/api/search/health').then(r => r.json()),
      fetch('/api/consultation/health').then(r => r.json()),
      fetch('/api/stats').then(r => r.json())
    ]);
    const setDot = (id, ok) => document.getElementById(id).className = 'status-dot' + (ok ? '' : ' red');
    setDot('st-esDot',    esH.status === 'fulfilled'    && esH.value.alive);
    setDot('st-neo4jDot', neo4jH.status === 'fulfilled' && neo4jH.value.alive);
    if (esH.status === 'fulfilled')
      document.getElementById('st-esChunks').textContent = (esH.value.count || 0).toLocaleString('fr');
    if (statsR.status === 'fulfilled') {
      const s = statsR.value;
      document.getElementById('st-neoChunks').textContent = (s.totalChunks      || 0).toLocaleString('fr');
      document.getElementById('st-entities').textContent  = (s.totalEntities    || 0).toLocaleString('fr');
      document.getElementById('st-relations').textContent = (s.totalRelations   || 0).toLocaleString('fr');
      document.getElementById('st-lois').textContent      = (s.loisCount        || 0).toLocaleString('fr');
      document.getElementById('st-notes').textContent     = (s.notesCount       || 0).toLocaleString('fr');
      document.getElementById('st-codes').textContent     = (s.codesCount       || 0).toLocaleString('fr');
      document.getElementById('st-conv').textContent      = (s.conventionsCount || 0).toLocaleString('fr');
      document.getElementById('st-text').textContent      = (s.textChunks       || 0).toLocaleString('fr');
      document.getElementById('st-table').textContent     = (s.tableChunks      || 0).toLocaleString('fr');
      document.getElementById('st-gnn').textContent       = s.gnnActive ? '✅ Actif' : '❌ Inactif';
    }
  } catch(e) { console.warn('stat panel failed', e); }
}

// ═══════════════════════════════════════════════════
// CONSULTATION GENERATION
// ═══════════════════════════════════════════════════

// ── Document chips ────────────────────────────────────────────────────────────
function addDoc() {
  const inp = document.getElementById('docInput');
  const val = inp.value.trim();
  if (!val) return;
  docs.push(val);
  inp.value = '';
  renderDocChips();
}

function removeDoc(i) {
  docs.splice(i, 1);
  renderDocChips();
}

function renderDocChips() {
  const container = document.getElementById('docChips');
  container.innerHTML = docs.map((d, i) =>
    `<div class="doc-chip">
      <span>${escHtml(d)}</span>
      <button class="doc-chip-remove" onclick="removeDoc(${i})" title="Retirer">✕</button>
    </div>`
  ).join('');
}

// ── Progress steps ────────────────────────────────────────────────────────────
const STEPS = ['retrieve','facts','scope','analysis','abbr','word'];

function setStep(step, state) {
  const el   = document.getElementById(`step-${step}`);
  const icon = document.getElementById(`icon-${step}`);
  if (!el) return;
  el.className = 'progress-step ' + state;
  if (state === 'active')   icon.innerHTML = '<span class="step-spinner"></span>';
  else if (state === 'done') icon.textContent = '✅';
  else                       icon.textContent = '⬜';
}

function resetSteps() {
  STEPS.forEach(s => setStep(s, 'pending'));
  document.getElementById('downloadArea').style.display = 'none';
  lastDocBlob = null;
}

// ── Main generation ───────────────────────────────────────────────────────────
async function generateConsultation() {
  const situation = document.getElementById('consSituation').value.trim();
  const question  = document.getElementById('consQuestion').value.trim();

  if (!situation) { toast('Veuillez décrire la situation du client.', 'error'); return; }
  if (!question)  { toast('Veuillez préciser la question fiscale.', 'error'); return; }

  const payload = {
    reference:     document.getElementById('consRef').value.trim() || `CONS-${new Date().getFullYear()}-XXX`,
    clientName:    document.getElementById('consClient').value.trim() || 'Client',
    situation,
    fiscalQuestion: question,
    documents:     [...docs]
  };

  const btn = document.getElementById('generateBtn');
  btn.disabled = true;
  btn.textContent = '⏳ Génération en cours…';
  resetSteps();

  // Animate progress steps (approximate timing; server is the source of truth)
  setStep('retrieve', 'active');
  const stepTimers = [
    setTimeout(() => { setStep('retrieve','done'); setStep('facts','active'); },  4000),
    setTimeout(() => { setStep('facts','done');    setStep('scope','active'); },  12000),
    setTimeout(() => { setStep('scope','done');    setStep('analysis','active');},18000),
    setTimeout(() => { setStep('analysis','done'); setStep('abbr','active'); },   45000),
    setTimeout(() => { setStep('abbr','done');     setStep('word','active'); },   55000),
  ];

  try {
    const resp = await fetch('/api/consultation/generate', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(payload)
    });

    stepTimers.forEach(clearTimeout);
    STEPS.forEach(s => setStep(s, 'done'));

    if (!resp.ok) {
      const err = await resp.json().catch(() => ({ error: `HTTP ${resp.status}` }));
      throw new Error(err.error || `HTTP ${resp.status}`);
    }

    // Get file as blob and prepare download
    const blob = await resp.blob();
    const cd   = resp.headers.get('Content-Disposition') || '';
    lastDocName = cd.match(/filename="?([^";]+)"?/)?.[1] || `Consultation_${payload.reference}.docx`;
    lastDocBlob = blob;

    const area = document.getElementById('downloadArea');
    area.style.display = 'block';
    document.getElementById('downloadBtn').onclick = triggerDownload;
    triggerDownload(); // auto-download

    toast('Consultation générée avec succès !', 'success');

  } catch(e) {
    stepTimers.forEach(clearTimeout);
    STEPS.forEach(s => { const el = document.getElementById(`icon-${s}`); if (el?.textContent === '⬜') {} });
    setStep('word', 'pending');
    toast(`Erreur : ${e.message}`, 'error');
    console.error(e);
  } finally {
    btn.disabled  = false;
    btn.textContent = '🚀 Générer la Consultation';
  }
}

function triggerDownload() {
  if (!lastDocBlob) return;
  const url = URL.createObjectURL(lastDocBlob);
  const a   = document.createElement('a');
  a.href     = url;
  a.download = lastDocName;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

// ═══════════════════════════════════════════════════
// SEARCH ENGINE
// ═══════════════════════════════════════════════════

function quickSearch(q) {
  showTab('search');
  document.getElementById('searchInput').value = q;
  doSearch();
}

async function doSearch() {
  const query = document.getElementById('searchInput').value.trim();
  if (!query) return;
  const btn = document.getElementById('searchBtn');
  btn.innerHTML = '<span style="display:inline-block;width:14px;height:14px;border:2px solid #fff;border-top-color:transparent;border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle;margin-right:6px"></span>Recherche…';
  btn.disabled = true;
  const container = document.getElementById('searchResults');
  container.innerHTML = renderSkeletons();
  showingAll = false;
  try {
    const payload = {
      query,
      docType:   document.getElementById('filterDocType').value,
      chunkType: document.getElementById('filterChunkType').value,
      yearMin:   parseInt(document.getElementById('yearMin').value) || 2000,
      yearMax:   parseInt(document.getElementById('yearMax').value) || 2030,
      size: 50
    };
    const resp = await fetch('/api/search', {
      method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(payload)
    });
    if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
    searchData = await resp.json();
    renderSearchResults(searchData, query);
  } catch(e) {
    container.innerHTML = `<div class="empty-state"><div class="empty-icon">⚠️</div>
      <div class="empty-title">Erreur de connexion</div>
      <div class="empty-sub">Elasticsearch inaccessible.<br/><small>${escHtml(e.message)}</small></div></div>`;
    toast(e.message, 'error');
  } finally {
    btn.innerHTML = '🔍 Rechercher'; btn.disabled = false;
  }
}

function renderSkeletons() {
  return Array(3).fill(0).map(() =>
    `<div class="result-card top">
      <div class="skeleton" style="height:14px;width:60%;margin-bottom:8px"></div>
      <div class="skeleton" style="height:11px;width:40%;margin-bottom:10px"></div>
      <div class="skeleton" style="height:40px;width:100%"></div>
    </div>`).join('');
}

function renderSearchResults(data, query) {
  const container = document.getElementById('searchResults');
  if (!data.hits?.length) {
    container.innerHTML = `<div class="empty-state"><div class="empty-icon">🔎</div>
      <div class="empty-title">Aucun résultat</div>
      <div class="empty-sub">Essayez d'autres mots-clés ou désactivez les filtres.</div></div>`;
    return;
  }
  const {hits, total, elapsedMs, maxScore, docTypeBuckets, chunkTypeBuckets} = data;
  let html = `<div class="metrics-row">
    <div class="metric-pill">Résultats : <b>${total.toLocaleString('fr')}</b></div>
    <div class="metric-pill">Temps : <b>${Math.round(elapsedMs)} ms</b></div>
    <div class="metric-pill">Meilleur score : <b>${(maxScore||0).toFixed(2)}</b></div>
  </div>`;
  const allBuckets = [...(docTypeBuckets||[]), ...(chunkTypeBuckets||[])];
  if (allBuckets.length) {
    html += '<div class="tags-row" style="margin-bottom:14px">';
    allBuckets.forEach(b => {
      html += `<span class="tag ${TAG_CSS[b.key]||'tag-other'}">${TAG_LABELS[b.key]||b.key}: ${b.count}</span>`;
    });
    html += '</div>';
  }
  html += `<h3 style="font-family:'Playfair Display',serif;font-size:16px;color:var(--black);margin-bottom:12px">🏆 Top résultats <span style="font-size:12px;color:var(--muted);font-weight:400;font-family:'DM Sans',sans-serif">— classés par pertinence BM25</span></h3>`;
  hits.slice(0,5).forEach((h,i) => html += renderCard(h, i+1, maxScore, true));
  if (hits.length > 5) {
    html += `<div class="section-divider">↓ ${hits.length-5} résultats supplémentaires ↓</div>`;
    html += `<button class="show-more-btn" id="showMoreBtn" onclick="toggleMore()">Afficher les ${hits.length-5} résultats suivants ▼</button>`;
    html += '<div id="moreResults" style="display:none">';
    hits.slice(5).forEach((h,i) => html += renderCard(h, i+6, maxScore, false));
    html += '</div>';
  }
  container.innerHTML = html;
}

function toggleMore() {
  showingAll = !showingAll;
  document.getElementById('moreResults').style.display = showingAll ? '' : 'none';
  document.getElementById('showMoreBtn').textContent = showingAll ? 'Masquer ▲' : 'Afficher les résultats suivants ▼';
}

function renderCard(hit, rank, maxScore, isTop) {
  const pct = Math.max(2, Math.min(100, Math.round((hit.score / Math.max(maxScore,0.01)) * 100)));
  const title = [hit.filename, hit.articleNumber ? `Art. ${hit.articleNumber}` : '', hit.sectionTitle]
    .filter(Boolean).join(' — ') || 'Sans titre';
  const page = hit.pageNumber ? ` · p.${hit.pageNumber}` : '';
  const lbl  = TAG_LABELS[hit.chunkType]    || hit.chunkType;
  const css  = TAG_CSS[hit.chunkType]       || 'tag-other';
  const dlbl = TAG_LABELS[hit.documentType] || hit.documentType;
  const dcss = TAG_CSS[hit.documentType]    || 'tag-other';
  return `
  <div class="result-card ${isTop ? 'top' : 'rest'}">
    <div class="card-row">
      <span class="card-rank">#${rank}</span>
      <span class="card-title">${escHtml(title)}</span>
      <span class="card-score-badge">${hit.score.toFixed(2)}</span>
    </div>
    <div class="tags-row">
      ${dlbl ? `<span class="tag ${dcss}">${escHtml(dlbl)}</span>` : ''}
      <span class="tag ${css}">${escHtml(lbl)}</span>
    </div>
    <div class="snippet">${sanitizeHighlight(hit.highlight) || escHtml((hit.content||'').slice(0,300)+'…')}</div>
    <div class="score-track"><div class="score-fill" style="width:${pct}%"></div></div>
    <div class="card-meta">${escHtml(hit.filename)}${page}</div>
  </div>`;
}

// ── Utilities ─────────────────────────────────────────────────────────────────
function sanitizeHighlight(rawHtml) {
  if (!rawHtml) return '';
  const stop = ['de','la','le','à','au','que','et','ou','un','une','du','des','en','par','pour','avec','sans','sur','dans','entre'];
  stop.forEach(w => { rawHtml = rawHtml.replace(new RegExp(`<em>${w}</em>`,'gi'), w); });
  // Only allow <em> tags — escape everything else
  return rawHtml.split(/(<\/?em>)/gi)
    .map(p => /^<\/?em>$/i.test(p) ? p : escHtml(p)).join('');
}

function toast(msg, type) {
  const c = document.getElementById('toastContainer');
  const t = document.createElement('div');
  t.className = `toast ${type||''}`;
  t.textContent = msg;
  c.appendChild(t);
  setTimeout(() => t.remove(), 5000);
}

function escHtml(s) {
  if (!s) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

// ── Consultation history search ───────────────────────────────────────────────
async function searchHistory() {
  const input   = document.getElementById('consultInput');
  const results = document.getElementById('historyResults');
  const client  = (input.value || '').trim();
  if (!client) return;

  results.innerHTML = '<div style="color:var(--muted);font-size:13px;padding:8px">Recherche en cours…</div>';

  try {
    const resp = await fetch('/api/consultation/history?client=' + encodeURIComponent(client));
    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    const data = await resp.json();

    if (!data.length) {
      results.innerHTML = `
        <div class="empty-state" style="padding:20px">
          <div class="empty-icon">📭</div>
          <div class="empty-title">Aucune consultation trouvée</div>
          <div class="empty-sub">Aucune consultation pour "<b>${escHtml(client)}</b>".<br/>
          Générez d'abord une consultation via l'onglet <b>Consultation IA</b>.</div>
        </div>`;
      return;
    }

    results.innerHTML =
      `<div style="font-size:12px;color:var(--muted);margin-bottom:10px">
        ${data.length} consultation(s) trouvée(s) pour <b>${escHtml(client)}</b>
       </div>`
      + data.map((c, i) => renderHistoryCard(c, i)).join('');

  } catch(e) {
    results.innerHTML = `<div style="color:var(--red);font-size:13px;padding:8px">
      Erreur: ${escHtml(e.message)}</div>`;
  }
}

function renderHistoryCard(c, i) {
  const id       = 'hcard_' + i;
  const sommaire = (c.sommaire || '').slice(0, 500);
  const analyses = (c.analyses || '');
  const hasSom   = sommaire.length > 0;
  const hasAna   = analyses.length > 0;

  return `
  <div class="consult-card">
    <div class="consult-client">📄 ${escHtml(c.client_name || '')}</div>
    <div class="consult-meta">
      <span>📅 ${escHtml(c.date        || '')}</span>
      <span>🔖 ${escHtml(c.reference   || '')}</span>
      <span>⚙️ ${escHtml(c.method      || '')}</span>
      <span>📚 ${c.sources_count || 0} sources</span>
      <span>⏱ ${c.elapsed_min   || 0} min</span>
    </div>
    ${hasSom ? `<div class="consult-sommaire">${escHtml(sommaire)}${(c.sommaire||'').length > 500 ? '…' : ''}</div>` : ''}
    ${hasAna ? `
      <button class="consult-expand-btn" id="btn_${id}"
        onclick="
          const el  = document.getElementById('${id}');
          const btn = document.getElementById('btn_${id}');
          const show = el.style.display !== 'block';
          el.style.display  = show ? 'block' : 'none';
          btn.textContent   = show ? '▲ Masquer les analyses' : '▼ Voir les analyses complètes';
        ">▼ Voir les analyses complètes</button>
      <div class="consult-analyses" id="${id}">${escHtml(analyses)}</div>
    ` : ''}
  </div>`;
}
// ── Init ──────────────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  loadStats();
  // Default state
  document.getElementById('sbQuickSearch').style.display = '';
  document.getElementById('sbFilters').style.display     = '';
  document.getElementById('searchInput').focus();
});
</script>
</body>
</html>
